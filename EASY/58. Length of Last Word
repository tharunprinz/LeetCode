class Solution {
    public int lengthOfLastWord(String s) {
       
        int count=0;
        int a = s.length()-1;
        while (a >= 0 && s.charAt(a) == ' '){
            a--;
        }

        while(a >= 0 && s.charAt(a) != ' '){
            count++;
            a--;
        }return count;
        
       
    }
}
